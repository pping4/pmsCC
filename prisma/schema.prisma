  UNDEPOSITED_FUNDS      // cash drop in-transit
  CARD_CLEARING          // credit-card settlement pending
  AR                     // guest receivable
  AR_CORPORATE           // city ledger
  DEPOSIT_LIABILITY      // guest deposits held
  AGENT_PAYABLE          // OTA commission payable
  VAT_OUTPUT
  VAT_INPUT
  SERVICE_CHARGE_PAYABLE
  ROOM_REVENUE
  FB_REVENUE
  PENALTY_REVENUE
  DISCOUNT_GIVEN
  CARD_FEE
  BANK_FEE

    "next": "14.2.3",
    "next-auth": "^4.24.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1",
    "regenerator-runtime": "^0.14.1",
    "tailwind-merge": "^2.3.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",

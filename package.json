    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "dotenv-cli": "^7.4.2",
    "pg": "^8.20.0",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
